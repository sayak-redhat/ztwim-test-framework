# ZTWIM Test Framework Environment Variables
# ==========================================
# Copy this to .env or export in your shell

# ===================
# REQUIRED: Cluster Access
# ===================

# Path to kubeconfig file
KUBECONFIG=~/.kube/config

# ===================
# OPTIONAL: Override Defaults
# ===================

# OpenShift apps domain (auto-detected if not set)
# APP_DOMAIN=apps.your-cluster.example.com

# ZTWIM cluster name
# CLUSTER_NAME=test01

# ===================
# OPTIONAL: AI Test Generation
# ===================

# For auto_gen.py API mode (not needed if using --use-cli)
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub token for private repos or rate limits
# GITHUB_TOKEN=ghp_...

# Default GitHub repo for PR lookups
# GITHUB_REPO=openshift/zero-trust-workload-identity-manager
